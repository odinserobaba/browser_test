{
  "name": "ai-playwright-recorder",
  "version": "1.0.0",
  "description": "AI-powered Playwright test recorder Chrome extension",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build --mode production && node scripts/copy-static.js",
    "preview": "vite preview",
    "postbuild": "node scripts/copy-static.js",
    "check": "node check-build.js"
  },
  "keywords": [
    "playwright",
    "test-automation",
    "ai",
    "recorder",
    "chrome-extension"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "typescript": "^5.3.2",
    "vite": "^5.0.5",
    "vite-plugin-static-copy": "^1.0.1"
  },
  "dependencies": {
    "openai": "^4.20.0"
  }
}
