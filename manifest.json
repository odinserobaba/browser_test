{
  "manifest_version": 3,
  "name": "AI Playwright Recorder",
  "version": "1.0.0",
  "description": "Record browser interactions and generate robust Playwright tests with AI-powered locator generation",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "downloads",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "AI Playwright Recorder"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_chrome_version": "114",
  "web_accessible_resources": [
    {
      "resources": ["content/index.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
